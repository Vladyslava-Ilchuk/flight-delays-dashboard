    <worksheet name='Scatter Plot_Cancellation vs Delay'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#536188' fontsize='12'>Cancellation vs Delay Airlines</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#555555'>Upper right quadrant = underperformers on both metrics</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#555555'>Lower left quadrant = best airlines</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
