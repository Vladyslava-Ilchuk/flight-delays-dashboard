      <column caption='Is Delayed' datatype='boolean' name='[Calculation_4661222750404612]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Departure Delay] &gt; 0' />
      </column>
      <column caption='Cancelled Flights Count' datatype='integer' name='[Calculation_4661222750498821]' role='measure' type='quantitative'>
