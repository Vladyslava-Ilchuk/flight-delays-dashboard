        <calculation class='tableau' formula='MAKEDATE([Year], [Month], [DAY])' />
      </column>
      <column caption='Cancellation Reason Full' datatype='string' name='[Calculation_4661222750240771]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Cancellation Reason]&#10;  WHEN &apos;A&apos; THEN &apos;Airline / Carrier&apos;&#10;  WHEN &apos;B&apos; THEN &apos;Weather&apos;&#10;  WHEN &apos;C&apos; THEN &apos;National Air System&apos;&#10;  WHEN &apos;D&apos; THEN &apos;Security&apos;&#10;  ELSE &apos;Not Cancelled&apos;&#10;END' />
