              <calculation class='tableau' formula='MAKEDATE([Year], [Month], [DAY])' />
            </column>
            <column caption='Cancellation Rate' datatype='real' default-format='p0.0%' name='[Calculation_4661222750756871]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Cancelled] = 1 THEN 1 ELSE 0 END) / COUNT([Flight Number])' />
            </column>
            <column caption='Delay Rate' datatype='real' default-format='p0.0%' name='[Calculation_4661222750867464]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Departure Delay] &gt; 0 &#10;THEN 1 &#10;ELSE 0 END) / &#10;COUNT([Flight Number])' />
            </column>
            <column caption='Total Flights' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_4661222751137802]' role='measure' type='quantitative'>
